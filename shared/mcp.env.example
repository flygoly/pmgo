# Shared MCP environment for pmgo (OpenClaw and Hermes).
# Copy values into your gateway MCP server `env` block.
# See runtimes/openclaw/README.md and runtimes/hermes/README.md.

# Required: absolute path to this repository
PMGO_WORKSPACE=/absolute/path/to/pmgo

# Optional: default project for reports / risk scan (from gtd:bootstrap output)
PMGO_DEFAULT_PROJECT_ID=
PMGO_DEFAULT_LOCALE=en

# Optional: override SQLite path (default: $PMGO_WORKSPACE/memory/pmgo.db)
# PMGO_MEMORY_DB=

# Optional: GitHub Issues integration
# GITHUB_TOKEN=
# GITHUB_REPO=owner/name

# Optional: Linear
# LINEAR_API_KEY=

# Optional: Jira Cloud
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# JIRA_PROJECT=
