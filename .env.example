# Copy to `.env` for local development or document variables for OpenClaw MCP `env` blocks.
# Never commit a filled `.env` (see `.gitignore`).

# Optional: override SQLite path (default: <pmgo repo>/memory/pmgo.db)
# PMGO_MEMORY_DB=/absolute/path/to/pmgo.db

# OpenClaw stdio MCP: set to the absolute path of this repository so tools resolve memory/policy/locales.
# PMGO_WORKSPACE=/absolute/path/to/pmgo

# GitHub Issues CLI + MCP (integration-github)
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=owner/name

# Linear GraphQL CLI + MCP (integration-linear)
# LINEAR_API_KEY=lin_api_...
