# Copy to `.env` for local development or document variables for MCP `env` blocks.
# Canonical list: shared/mcp.env.example
# Never commit a filled `.env` (see `.gitignore`).

# Optional: override SQLite path (default: <pmgo repo>/memory/pmgo.db)
# PMGO_MEMORY_DB=/absolute/path/to/pmgo.db

# OpenClaw stdio MCP: set to the absolute path of this repository so tools resolve memory/policy/locales.
# PMGO_WORKSPACE=/absolute/path/to/pmgo

# Default project for reports / risk scan (set after `npm run gtd:bootstrap -- --name "My GTD"`)
# PMGO_DEFAULT_PROJECT_ID=<uuid-from-bootstrap-output>
# PMGO_DEFAULT_LOCALE=en

# GitHub Issues CLI + MCP (integration-github)
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=owner/name

# Linear GraphQL CLI + MCP (integration-linear)
# LINEAR_API_KEY=lin_api_...

# Jira Cloud REST CLI + MCP (integration-jira)
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=
# JIRA_PROJECT=PROJ

# Feishu (integration-feishu) — add app as tasklist member for list/import
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_TASKLIST_GUID=

# Notion (integration-notion) — share the database with the integration
# NOTION_TOKEN=
# NOTION_DATABASE_ID=

# DingTalk scaffold (integration-dingtalk)
# DINGTALK_APP_KEY=
# DINGTALK_APP_SECRET=
