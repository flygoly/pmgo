{
  "name": "pmgo",
  "version": "0.1.0",
  "private": true,
  "description": "pmgo - OpenClaw-based AI project manager agent and skills pack.",
  "license": "Apache-2.0",
  "scripts": {
    "check": "node scripts/validate-agent-i18n.js",
    "check:agent-i18n": "node scripts/validate-agent-i18n.js",
    "check:agent-i18n:strict": "node scripts/validate-agent-i18n.js --strict",
    "check:agent-i18n:strict:json": "node scripts/validate-agent-i18n.js --strict --json",
    "validate:memory": "npm run memory:check && npm run memory:init && npm run memory:migrate && npm run memory:verify",
    "project-core:smoke": "python3 scripts/project-core.py project-list",
    "project-core": "python3 scripts/project-core.py",
    "validate": "npm run check && npm run validate:memory && npm run project-core:smoke",
    "memory:init": "python3 scripts/init-memory-db.py",
    "memory:init:project": "python3 scripts/init-memory-project.py",
    "memory:migrate": "python3 scripts/migrate-memory-db.py",
    "memory:check": "python3 scripts/check-memory-assets.py",
    "memory:scaffold": "python3 scripts/scaffold-memory.py",
    "memory:verify": "python3 scripts/verify-memory-db.py",
    "test": "echo \"No tests configured yet\""
  }
}
